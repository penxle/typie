{
  "$schema": "https://turbo.build/schema.json",
  "remoteCache": {
    "apiUrl": "https://tdukab2pwvanvnh37p3qpjlgya0fkaes.lambda-url.ap-northeast-2.on.aws",
    "teamSlug": "typie",
    "preflight": true
  },
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "codegen": {
      "dependsOn": ["^build"],
      "outputs": [".svelte-kit/**", ".mearie/**", "styled-system/**"]
    },
    "build": {
      "dependsOn": ["codegen", "^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "dependsOn": ["codegen"],
      "persistent": true,
      "cache": false
    },
    "lint:eslint": {
      "dependsOn": ["codegen"]
    },
    "lint:svelte": {
      "dependsOn": ["^codegen", "codegen"]
    },
    "lint:typecheck": {
      "dependsOn": ["codegen"]
    },
    "test": {
      "dependsOn": ["codegen"],
      "outputs": ["coverage/**"]
    }
  }
}
