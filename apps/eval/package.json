{
  "name": "@typie/eval",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "codegen": "svelte-kit sync && panda codegen",
    "db:migrate": "wrangler d1 migrations apply typie-eval --remote",
    "deploy": "vite build && wrangler deploy",
    "dev": "vite dev",
    "lint:eslint": "eslint --max-warnings 0 .",
    "lint:svelte": "svelte-check --fail-on-warnings",
    "test": "vitest run"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260714.1",
    "@iconify-json/lucide": "^1.2.116",
    "@pandacss/dev": "^1.11.4",
    "@sveltejs/adapter-cloudflare": "^7.2.4",
    "@sveltejs/kit": "^2.69.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.4",
    "@types/node": "^26.1.0",
    "@typie/lib": "workspace:*",
    "@typie/styled-system": "workspace:*",
    "@typie/tsconfig": "workspace:*",
    "@typie/ui": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "nanoid": "^5.1.16",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "typescript": "^6.0.3",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.1.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0",
    "zod": "^4.4.3"
  }
}
