{
  "name": "@typie/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "doppler run -- concurrently -r \"pnpm run dev:tsdown\" \"pnpm run dev:node\"",
    "dev:email": "email dev --port 3001 --dir src/email/templates",
    "dev:node": "node --watch --watch-preserve-output src/main.ts",
    "dev:tsdown": "tsdown --watch",
    "lint:eslint": "eslint --max-warnings 0 .",
    "lint:typecheck": "tsc",
    "start": "node --import ./src/instrumentation.ts src/main.ts"
  },
