{
  "name": "@typie/editor",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./pkg/editor.d.ts",
      "default": "./pkg/editor.js"
    },
    "./font/defaults.json": "./assets/defaults.json",
    "./font/fallbacks.json": "./assets/fallbacks.json",
    "./font/Noto-Phantom.bin": "./assets/Noto-Phantom.bin",
    "./font/Noto-Phantom-Emoji.bin": "./assets/Noto-Phantom-Emoji.bin",
    "./icu.zst": "./pkg/icu.zst",
    "./theme.json": "./assets/theme.json"
  },
  "main": "pkg/editor.js",
  "types": "pkg/editor.d.ts",
  "files": [
    "pkg"
  ],
  "scripts": {
    "android:build": "scripts/build_android.sh debug",
    "android:release": "scripts/build_android.sh release",
    "assets": "scripts/build_assets.sh",
    "ios:build": "scripts/build_ios.sh debug",
    "ios:release": "scripts/build_ios.sh release",
    "mobile:build": "scripts/build_mobile.sh all debug",
    "mobile:release": "scripts/build_mobile.sh all release",
    "wasm:build": "RUSTFLAGS=\"-C target-feature=+simd128\" wasm-pack build --target=web --no-pack --dev",
    "wasm:release": "RUSTFLAGS=\"-C target-feature=+simd128\" wasm-pack build --target=web --no-pack"
  }
}
