{
  "name": "@typie/monorepo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/api",
    "apps/bmo",
    "apps/caddy",
    "apps/literoom",
    "apps/mobile",
    "apps/website",
    "crates/*",
    "packages/*"
  ],
  "scripts": {
    "bootstrap": "lefthook install",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint:eslint": "eslint --max-warnings 0 .",
    "lint:prettier": "prettier --check --ignore-unknown '**/*'",
    "lint:spellcheck": "cspell --no-progress --relative '**/*'",
    "lint:svelte": "turbo run lint:svelte",
    "lint:syncpack": "syncpack lint",
    "lint:typecheck": "turbo run lint:typecheck",
    "test": "turbo run test"
  },
  "overrides": {
    "canvas": "npm:-",
    "ioredis": "^5.9.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@typie/lintconfig": "workspace:*",
    "cspell": "^9.6.4",
    "eslint": "^9.39.2",
    "lefthook": "^2.1.1",
    "prettier": "^3.8.1",
    "syncpack": "^14.0.0",
    "turbo": "^2.8.10",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.0"
}
