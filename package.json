{
  "name": "@typie/monorepo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "bootstrap": "lefthook install",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint:eslint": "eslint --max-warnings 0 .",
    "lint:prettier": "prettier --check --ignore-unknown '**/*'",
    "lint:spellcheck": "cspell --no-progress --relative '**/*'",
    "lint:svelte": "turbo run lint:svelte",
    "lint:syncpack": "syncpack lint",
    "lint:typecheck": "turbo run lint:typecheck",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@typie/lintconfig": "workspace:*",
    "cspell": "^9.7.0",
    "eslint": "^9.39.3",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "syncpack": "^14.2.0",
    "turbo": "^2.8.17",
    "typescript": "^6.0.1-rc"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "typescript": ">=6"
      }
    },
    "overrides": {
      "ioredis": "^5.10.0"
    }
  }
}
